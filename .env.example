# 环境变量配置示例
# 复制此文件为 .env 并修改相关配置

# 服务器端口
PORT=3000

# JWT 密钥（务必修改）
JWT_SECRET=bounty-pavilion-secret-key-change-in-production

# DeepSeek API 密钥（AI聊天机器人用，不配置则只使用预设问答）
DEEPSEEK_API_KEY=your-deepseek-api-key

# Node 环境
NODE_ENV=production

# ========== 邮件服务配置（QQ邮箱） ==========
# SMTP 服务器（QQ邮箱固定为 smtp.qq.com）
SMTP_HOST=smtp.qq.com
# SMTP 端口（SSL为465，TLS为587）
SMTP_PORT=465
# SMTP 邮箱账号
SMTP_USER=3463195663@qq.com
# SMTP 授权码（不是QQ密码！在QQ邮箱设置→账户→POP3/SMTP服务中获取）
SMTP_PASS=mtqlprnrehbodcaf
# 发件人显示邮箱（默认与 SMTP_USER 相同）
EMAIL_FROM=3463195663@qq.com

# 网站地址（用于邮件中生成链接）
SITE_URL=https://your-domain.com
